{
  "name": "oj-multimedia",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "test": "npm run test:unit",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:phase": "vitest run --config vitest.phase.config.ts",
    "test:phase:unit": "vitest run --config vitest.phase.config.ts tests/phase/unit",
    "test:phase:integration": "vitest run --config vitest.phase.config.ts tests/phase/integration",
    "test:phase:e2e": "playwright test -c playwright.phase.config.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:next": "next lint",
    "format": "prettier --write . --ignore-path .prettierignore",
    "format:check": "prettier --check . --ignore-path .prettierignore",
    "analyze": "cross-env ANALYZE=true next build --turbopack",
    "checks:performance": "node scripts/verify-bundle-budget.mjs && node scripts/lighthouse-budget.mjs",
    "lighthouse:budget": "node scripts/lighthouse-budget.mjs",
    "checks": "npm run lint && npm run format:check && npm run test:unit && rm -rf .next && npm run build && npm run checks:performance",
    "audit": "npm audit",
    "audit:ci": "npm audit --audit-level=high",
    "generate:icons": "npx @svgr/cli --out-dir components/icons --ignore-existing --typescript --replace-attr-values #fff=currentColor,#000=currentColor --jsx-runtime automatic --icon -- public/icons"
  },
  "keywords": [
    "nextjs",
    "nextjs-16",
    "tailwindcss",
    "shadcn",
    "fullstack",
    "typescript",
    "mongodb",
    "cloudflare",
    "r2",
    "storage"
  ],
  "author": "Codegiyu",
  "license": "ISC",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-email/render": "^2.0.2",
    "axios": "^1.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "libphonenumber-js": "^1.11.14",
    "lodash": "^4.17.21",
    "lucide-react": "^0.544.0",
    "media-chrome": "^4.17.2",
    "motion": "^12.29.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.9.17",
    "nuqs": "^2.7.2",
    "radix-ui": "^1.4.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-icons": "^5.5.0",
    "sonner": "^2.0.7",
    "swiper": "^12.1.4",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5",
    "zod": "^4.1.5",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.58.2",
    "@svgr/cli": "^8.1.0",
    "@tailwindcss/postcss": "^4",
    "@types/google-libphonenumber": "^7.4.30",
    "@types/lodash": "^4.17.20",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/swiper": "^5.4.3",
    "baseline-browser-mapping": "^2.9.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.6.2",
    "sharp": "^0.34.4",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.8",
    "typescript-eslint": "^8.47.0",
    "vitest": "^4.1.5",
    "@next/bundle-analyzer": "^16.2.4",
    "cross-env": "^7.0.3",
    "lighthouse": "^12.8.2"
  }
}
