{
  "name": "oj-multimedia",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "test": "npm run test:unit",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "cross-env PLAYWRIGHT_USE_WEBSERVER=1 playwright test --grep @smoke --project=chromium",
    "test:e2e:a11y": "cross-env PLAYWRIGHT_USE_WEBSERVER=1 playwright test tests/e2e/a11y-critical-journeys.spec.ts --project=chromium",
    "test:phase": "vitest run --config vitest.phase.config.ts",
    "test:phase:unit": "vitest run --config vitest.phase.config.ts tests/phase/unit",
    "test:phase:integration": "vitest run --config vitest.phase.config.ts tests/phase/integration",
    "test:phase:e2e": "playwright test -c playwright.phase.config.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:next": "next lint",
    "format": "prettier --write . --ignore-path .prettierignore",
    "format:check": "prettier --check . --ignore-path .prettierignore",
    "analyze": "cross-env ANALYZE=true next build --turbopack",
    "checks:performance": "node scripts/verify-bundle-budget.mjs && node scripts/lighthouse-budget.mjs",
    "lighthouse:budget": "node scripts/lighthouse-budget.mjs",
    "checks": "npm run lint && npm run format:check && npm run test:unit && rm -rf .next && npm run build && npm run checks:performance",
    "release:check": "npm run checks && npm run test:integration && npm run test:phase:integration && npm run test:e2e:smoke && npm run audit:ci",
    "audit": "npm audit",
    "audit:ci": "npm audit --audit-level=high",
    "generate:icons": "npx @svgr/cli --out-dir components/icons --ignore-existing --typescript --replace-attr-values #fff=currentColor,#000=currentColor --jsx-runtime automatic --icon -- public/icons",
    "generate:lucide-registry": "node scripts/generate-lucide-registry.mjs"
  },
  "keywords": [
    "nextjs",
    "nextjs-16",
    "tailwindcss",
    "shadcn",
    "fullstack",
    "typescript",
    "mongodb",
    "cloudflare",
    "r2",
    "storage"
  ],
  "author": "Codegiyu",
  "license": "ISC",
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.13",
    "@radix-ui/react-avatar": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-progress": "^1.1.9",
    "@radix-ui/react-scroll-area": "^1.2.11",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-switch": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@react-email/render": "^2.0.8",
    "axios": "^1.17.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "libphonenumber-js": "^1.13.6",
    "lucide-react": "^0.544.0",
    "media-chrome": "^4.19.1",
    "motion": "^12.40.0",
    "next": "16.2.7",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.9.17",
    "nuqs": "^2.8.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sonner": "^2.0.7",
    "swiper": "^12.2.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/eslintrc": "^3.3.5",
    "@next/bundle-analyzer": "^16.2.7",
    "@playwright/test": "^1.58.2",
    "@svgr/cli": "^8.1.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/google-libphonenumber": "^7.4.30",
    "@types/node": "^22.19.20",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19",
    "@types/swiper": "^5.4.3",
    "baseline-browser-mapping": "^2.9.2",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "lighthouse": "^13.3.0",
    "prettier": "^3.8.4",
    "sharp": "^0.34.4",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.3.8",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
